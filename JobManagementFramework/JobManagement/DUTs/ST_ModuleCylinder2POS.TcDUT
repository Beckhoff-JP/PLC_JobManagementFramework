	out_push AT%Q*	: BOOL;
	out_pull AT%Q*	: BOOL;
	timeout_push	: TIME;	
	timeout_pull	: TIME;	
	current_position : E_2Position := E_2Position.pos1; // pos1 : pull side, pos2: push side
END_STRUCT
END_TYPE
]]></Declaration>
