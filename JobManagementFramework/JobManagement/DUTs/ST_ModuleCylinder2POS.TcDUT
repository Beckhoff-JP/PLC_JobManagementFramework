  <DUT Name="ST_ModuleCylinder2POS" Id="{e676e669-0921-4690-b055-810b372eaa34}">
    <Declaration><![CDATA[TYPE ST_ModuleCylinder2POS :
STRUCT
	in_pos1	AT%I* : BOOL;
